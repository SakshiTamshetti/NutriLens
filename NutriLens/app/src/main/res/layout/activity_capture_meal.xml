<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/greenLight">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="Capture Your Meal"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/greenDark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Snap Food Photo"
            android:drawableStart="@drawable/ic_camera"
            android:textColor="@color/white"
            android:backgroundTint="@color/greenPrimary"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/editMeal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type your meal description"
            android:layout_marginTop="15dp"
            android:padding="12dp"
            android:background="@drawable/input_bg"/>

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Analyze Meal"
            android:backgroundTint="@color/greenDark"
            android:textColor="@color/white"
            android:layout_marginTop="15dp"/>

    </LinearLayout>

</ScrollView>